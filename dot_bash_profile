test -z "$PROFILEREAD" && . /etc/profile || true

export PATH="$PATH:/home/lukas/.emacs.d/bin/"

# Added by Toolbox App
export PATH="$PATH:/home/lukas/.local/share/JetBrains/Toolbox/scripts"

export EDITOR="/usr/bin/nvim"

# Used for niri with cursors installed
export XCURSOR_THEME=Adwaita
export XCURSOR_SIZE=24

# GUIX_PROFILE="/home/lukas/.guix-profile"
#      . "$GUIX_PROFILE/etc/profile"
#
# export GUIX_LOCPATH="$HOME/.guix-profile/lib/locale"

# export PATH="$HOME/.npm-global/bin:$PATH"
export PATH="$HOME/.nix-profile/bin:/nix/var/nix/profiles/default/bin:$PATH"

# Only trigger if:
# - 'fish' is not the parent process of this shell
# - We did not call: bash -c '...'
# - The fish binary exists and is executable
if [[ $(ps --no-header --pid=$PPID --format=comm) != "nu" && -z ${BASH_EXECUTION_STRING} && -x "$HOME/.guix-home/profile/bin/nu" ]]; then
  shopt -q login_shell && LOGIN_OPTION='--login' || LOGIN_OPTION=''
  exec nu $LOGIN_OPTION
fi
